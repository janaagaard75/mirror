    "Mirror needs access to your camera to use the screen as a mirror. It can't work without access to the camera.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتاج Mirror إلى الوصول إلى الكاميرا لاستخدام الشاشة كمرآة. لا يمكن للتطبيق العمل بدون الوصول إلى الكاميرا."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Mirror necessita accés a la càmera per utilitzar la pantalla com un mirall. L’app no pot funcionar sense accés a la càmera."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Mirror potřebuje přístup ke kameře, aby mohl používat obrazovku jako zrcadlo. Bez přístupu ke kameře aplikace nefunguje."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Mirror skal have adgang til dit kamera for at bruge skærmen som et spejl. Appen kan ikke fungere uden adgang til kameraet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mirror benötigt Zugriff auf deine Kamera, um den Bildschirm als Spiegel zu verwenden. Ohne Zugriff auf die Kamera funktioniert die App nicht."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Mirror χρειάζεται πρόσβαση στην κάμερα για να χρησιμοποιεί την οθόνη ως καθρέφτη. Η εφαρμογή δεν λειτουργεί χωρίς πρόσβαση στην κάμερα."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mirror necesita acceso a tu cámara para usar la pantalla como un espejo. La app no funciona sin acceso a la cámara."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Mirror necesita acceso a tu cámara para usar la pantalla como un espejo. La app no funciona sin acceso a la cámara."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
